# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al repositorio.

SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion
DEBUG=True

# En producción (DEBUG=False) es obligatorio. Separar por comas.
# Ejemplo: ALLOWED_HOSTS=midominio.com,www.midominio.com
ALLOWED_HOSTS=

# URL(s) del frontend. Separar por comas si hay varias.
# Ejemplo prod: CORS_ALLOWED_ORIGINS=https://miferreteria.com,https://www.miferreteria.com
CORS_ALLOWED_ORIGINS=http://localhost:4200
CSRF_TRUSTED_ORIGINS=http://localhost:4200

# Base de datos. En desarrollo se omite (usa SQLite).
# En producción: DATABASE_URL=postgres://usuario:password@host:5432/nombre_db
# DATABASE_URL=

# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Límites de peticiones (opcional, tienen defaults sensatos)
# THROTTLE_ANON=100/hour
# THROTTLE_USER=1000/hour
# THROTTLE_AUTH=10/min
